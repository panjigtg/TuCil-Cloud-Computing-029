---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pemilu Hokage">
    <main class="bg-white p-8 md:p-10 rounded-2xl shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] max-w-4xl w-full relative border-4 border-black">
		<div id="server-info" class="absolute top-4 right-4 bg-black text-white text-xs px-3 py-1.5 rounded-full hidden font-mono shadow-sm"></div>

		<header class="text-center mb-10 border-b-4 border-black pb-6">
			<h1 class="text-4xl md:text-5xl font-extrabold text-black tracking-tight mb-2 uppercase">WHO NEXT HOKAGE</h1>
			<p class="text-gray-600 font-medium">Gunakan hak suara Anda dengan bijak.</p>
		</header>
		
		<div id="login-section" class="max-w-md mx-auto my-8 transition-all">
			<div class="bg-white p-6 rounded-xl border-2 border-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
				<h2 class="text-lg font-bold mb-4 text-black text-center uppercase tracking-wide">Identifikasi Pemilih</h2>
				<input type="text" id="username" placeholder="Masukkan Nama Lengkap Anda..." class="w-full p-4 rounded-lg border-2 border-black focus:outline-none focus:ring-0 focus:bg-gray-100 mb-4 text-center text-lg font-semibold transition-colors placeholder-gray-500" />
				<button onclick="login()" class="w-full bg-black text-white font-bold uppercase py-4 px-6 rounded-lg hover:bg-white hover:text-black border-2 border-black transition-all duration-200">
					Masuk Ke Bilik Suara
				</button>
			</div>
		</div>

		<div id="voting-section" class="hidden my-8 animate-fade-in">
			<div class="bg-black text-white px-6 py-4 rounded-xl mb-8 flex items-center justify-between shadow-sm">
				<div class="flex items-center">
					<svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
						d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
					</svg>

					<p id="welcome-msg" class="text-lg font-bold tracking-wide"></p>
				</div>

				<button onclick="logout()"
					class="bg-red-600 text-white text-xs px-3 py-1 rounded border border-white hover:bg-white hover:text-red-600 transition-colors">
					LOGOUT
				</button>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
				<div class="bg-white border-2 border-black rounded-xl p-6 text-center hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-1 transition-all duration-300 group flex flex-col items-center">
					<div class="w-28 h-28 bg-gray-100 border-2 border-black rounded-full flex items-center justify-center text-6xl mb-4 grayscale group-hover:grayscale-0 transition-all shadow-sm">👨‍🎓</div>
					<h2 class="text-2xl font-black mb-6 text-black uppercase">Kandidat 01</h2>
					<button onclick="coblos(1)" class="mt-auto bg-black text-white font-bold uppercase py-3 px-6 w-full rounded-lg hover:bg-white hover:text-black border-2 border-black transition-colors">Coblos 01</button>
				</div>
				
				<div class="bg-white border-2 border-black rounded-xl p-6 text-center hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-1 transition-all duration-300 group flex flex-col items-center">
					<div class="w-28 h-28 bg-gray-100 border-2 border-black rounded-full flex items-center justify-center text-6xl mb-4 grayscale group-hover:grayscale-0 transition-all shadow-sm">👩‍🎓</div>
					<h2 class="text-2xl font-black mb-6 text-black uppercase">Kandidat 02</h2>
					<button onclick="coblos(2)" class="mt-auto bg-black text-white font-bold uppercase py-3 px-6 w-full rounded-lg hover:bg-white hover:text-black border-2 border-black transition-colors">Coblos 02</button>
				</div>

				<div class="bg-white border-2 border-black rounded-xl p-6 text-center hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-1 transition-all duration-300 group flex flex-col items-center">
					<div class="w-28 h-28 bg-gray-100 border-2 border-black rounded-full flex items-center justify-center text-6xl mb-4 grayscale group-hover:grayscale-0 transition-all shadow-sm">👩</div>
					<h2 class="text-2xl font-black mb-6 text-black uppercase">Kandidat 03</h2>
					<button onclick="coblos(3)" class="mt-auto bg-black text-white font-bold uppercase py-3 px-6 w-full rounded-lg hover:bg-white hover:text-black border-2 border-black transition-colors">Coblos 03</button>
				</div>
			</div>
		</div>

		<div class="bg-white p-6 rounded-xl border-4 border-black mt-4">
			<h3 class="font-bold uppercase tracking-widest mb-4 text-center text-black flex items-center justify-center gap-2">
				<span class="relative flex h-3 w-3">
					<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-gray-400 opacity-75"></span>
					<span class="relative inline-flex rounded-full h-3 w-3 bg-red-600"></span>
				</span>
				Live Skor Sementara
			</h3>
			<div class="flex justify-around text-center">
				<div>
					<div class="text-xs text-gray-500 font-bold mb-1">KANDIDAT 01</div>
					<div class="text-4xl font-black text-black" id="skor1">0</div>
				</div>
				<div>
					<div class="text-xs text-gray-500 font-bold mb-1">KANDIDAT 02</div>
					<div class="text-4xl font-black text-black" id="skor2">0</div>
				</div>
				<div>
					<div class="text-xs text-gray-500 font-bold mb-1">KANDIDAT 03</div>
					<div class="text-4xl font-black text-black" id="skor3">0</div>
				</div>
			</div>
		</div>
	</main>

    <style>
        .animate-fade-in {
            animation: fadeIn 0.4s ease-out forwards;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>

    <script is:inline>
		document.addEventListener("DOMContentLoaded", () => {
			const savedUser = localStorage.getItem("pemilih_nama");
			if (savedUser) {
				masukBilik(savedUser);
			}
			updateSkor();
		});

		function masukBilik(nama) {
			document.getElementById('login-section').classList.add('hidden');
			document.getElementById('voting-section').classList.remove('hidden');
			document.getElementById('welcome-msg').innerHTML = `
				<span>STATUS: AKTIF | PEMILIH: ${nama.toUpperCase()}</span>
			`;
		}

		function logout() {
			localStorage.removeItem("pemilih_nama");
			window.location.reload();
		}

		async function login(){
			const username = document.getElementById('username').value;
			if(!username) return alert("Nama Tidak Boleh Kosong!");
			try{
				const res = await fetch('/api/login', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ username })
				});
				const data = await res.json();
				if(res.ok) {
					localStorage.setItem("pemilih_nama", username);
					masukBilik(username);
					tampilkanServer(data.server);
					updateSkor();
				} else alert(data.error);
			} catch (e) { 
				alert("Gagal menghubungi server."); 
			}
		}

		async function coblos(nomor) {
			try {
				const res = await fetch('/api/vote', { 
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ paslon: nomor }) 
				});

				const data = await res.json();

				if (res.ok) {
					alert(data.message);
					updateSkor();
				} else {
					alert("GAGAL: " + data.error);
				}   
			} catch (e) { 
				alert("Gagal mengirim suara."); 
			}
		}

		function tampilkanServer(serverId) {
			if(!serverId) return;
			const info = document.getElementById('server-info');
			info.innerText = "Server ID: " + serverId;
			info.classList.remove('hidden');
		}

		async function updateSkor() {
			try {
				const res = await fetch('/api/skor');
				if(res.ok) {
					const data = await res.json();
					document.getElementById('skor1').innerText = data.paslon1 || 0;
					document.getElementById('skor2').innerText = data.paslon2 || 0;
					document.getElementById('skor3').innerText = data.paslon3 || 0;
				}
			} catch (e) { }
		}
		
		setInterval(updateSkor, 2000);
	</script>
</Layout>